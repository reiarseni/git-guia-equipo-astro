---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { groups, sections } from '../data/sections';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Git — Guía de Buenas Prácticas">
  <Sidebar slot="sidebar" />

  <div class="container">

    <!-- Hero -->
    <header class="hero">
      <div class="hero-tag">v3.0 — Estándar del Equipo</div>
      <h1 class="hero-title"><span class="hero-title-line">Buenas Prácticas</span>con <span class="hero-title-accent">Git</span></h1>
      <p class="hero-sub">Guía oficial del flujo de trabajo con Git y GitLab para el equipo de desarrollo.</p>
      <div class="pillars">
        <span class="pillar">Shared Repository</span>
        <span class="pillar">Feature Branches</span>
        <span class="pillar">Pull Requests</span>
        <span class="pillar">main + testing</span>
        <span class="pillar">GitLab Workitems</span>
        <span class="pillar">CI/CD</span>
        <span class="pillar">Squash Merge</span>
      </div>
      <a href={base + sections[0].href} class="cta-btn">
        Comenzar
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    </header>

    <!-- Índice de secciones -->
    <div class="toc">
      {groups.map(group => (
        <div class="toc-group">
          <span class="toc-group-label">{group.label}</span>
          <div class="toc-cards">
            {group.items.map(item => (
              <a href={base + item.href} class="toc-card">
                <span class="toc-title">{item.title}</span>
                <svg class="toc-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>

<style>
  .hero {
    padding: 40px 0 64px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 56px;
  }

  .hero-tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    background: rgba(124, 106, 247, 0.08);
    border: 1px solid rgba(124, 106, 247, 0.22);
    padding: 4px 12px;
    border-radius: 6px;
    margin-bottom: 24px;
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px, 6vw, 52px);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 18px;
  }

  .hero-title-line { display: block; }
  .hero-title-accent { color: var(--accent); }

  .hero-sub {
    font-size: clamp(14px, 2vw, 16px);
    color: var(--muted);
    max-width: 480px;
    margin-bottom: 28px;
  }

  .pillars {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 36px;
  }

  .pillar {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 6px;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--accent);
    color: #fff;
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .cta-btn:hover {
    background: #6a5ae0;
    transform: translateY(-1px);
  }

  .cta-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .toc {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-bottom: 80px;
  }

  .toc-group-label {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .toc-cards { display: grid; gap: 8px; }

  .toc-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.18s, background 0.18s, transform 0.14s;
  }

  .toc-card:hover {
    border-color: rgba(124, 106, 247, 0.4);
    background: var(--surface2);
    transform: translateX(4px);
  }

  .toc-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-color: rgba(124, 106, 247, 0.4);
  }

  .toc-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    background: rgba(124, 106, 247, 0.08);
    border: 1px solid rgba(124, 106, 247, 0.18);
    width: 34px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .toc-title {
    flex: 1;
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 600;
  }

  .toc-arrow {
    color: var(--muted);
    flex-shrink: 0;
    transition: transform 0.14s, color 0.14s;
  }

  .toc-card:hover .toc-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }
</style>
