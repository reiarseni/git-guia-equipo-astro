---
interface Props {
  title: string;
  id: string;
}

const { title, id } = Astro.props;
---

<div class="section" id={id}>
  <h2>{title}</h2>
  <slot />
</div>

<style>
  .section { margin-bottom: 68px; }
  h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    color: #fff;
    margin-bottom: 28px;
  }
</style>
