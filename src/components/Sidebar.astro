---
import { groups } from '../data/sections';

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // e.g. '/git-guia-equipo-astro'
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<div class="sidebar-inner">
  <div class="sidebar-head">
    <a href={import.meta.env.BASE_URL} class="sidebar-home-link">
      <p class="sidebar-title">Git Guía v4.0</p>
    </a>
    <div class="offline-pill offline-pill--sidebar" id="offlineBadgeSidebar" aria-live="polite" aria-atomic="true" hidden>
      <span class="offline-dot" aria-hidden="true"></span>Sin conexión
    </div>
  </div>

  <nav class="sidebar-nav" aria-label="Secciones de la guía">
    {groups.map(group => (
      <div class="nav-group">
        <span class="nav-group-label">{group.label}</span>
        <ul class="nav-list">
          {group.items.map(item => (
            <li>
              <a
                href={base + item.href}
                class:list={["nav-link", { "is-active": pathname === base + item.href }]}
                aria-current={pathname === base + item.href ? "page" : undefined}
              >
                <span class="nav-text">{item.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>

  <!-- Botón de instalación PWA (permanente) -->
  <div class="sidebar-foot" id="sidebar-install-foot" hidden>
    <button id="sidebar-install-btn" class="sidebar-install-btn" type="button">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Instalar como app
    </button>
  </div>
</div>

<style>
  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .sidebar-head {
    padding: 22px 20px 18px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .sidebar-home-link {
    text-decoration: none;
    display: block;
  }

  .sidebar-title {
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin: 0;
  }

  .sidebar-title span {
    display: block;
    color: var(--muted);
    font-weight: 400;
    font-size: 12px;
    margin-top: 2px;
  }

  .sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 16px 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .nav-group { margin-bottom: 22px; }

  .nav-group-label {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 8px;
    margin-bottom: 5px;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 7px;
    text-decoration: none;
    color: #9090aa;
    font-size: 13px;
    line-height: 1.35;
    transition: background 0.14s ease, color 0.14s ease;
    width: 100%;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
    outline: none;
  }

  .nav-link.is-active {
    background: rgba(124, 106, 247, 0.12);
    color: var(--accent);
  }

  .nav-text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Footer con botón de instalación ── */
  .sidebar-foot {
    padding: 12px 14px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  .sidebar-install-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 9px 12px;
    background: rgba(124, 106, 247, 0.08);
    border: 1px solid rgba(124, 106, 247, 0.2);
    border-radius: 8px;
    color: #a090f0;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    font-family: inherit;
  }

  .sidebar-install-btn:hover,
  .sidebar-install-btn:focus-visible {
    background: rgba(124, 106, 247, 0.15);
    color: #c0b0ff;
    border-color: rgba(124, 106, 247, 0.4);
    outline: none;
  }
</style>

<script>
  interface BeforeInstallPromptEvent extends Event {
    prompt(): Promise<{ outcome: 'accepted' | 'dismissed' }>;
  }

  // Escuchar el evento capturado por PwaInstallPrompt
  // El prompt se almacena en window.__pwaPrompt para compartirlo
  const foot = document.getElementById('sidebar-install-foot');
  const btn  = document.getElementById('sidebar-install-btn');

  function yaInstalada(): boolean {
    return window.matchMedia('(display-mode: standalone)').matches
        || (navigator as Navigator & { standalone?: boolean }).standalone === true;
  }

  function estadoPermanente(): boolean {
    try {
      const d = JSON.parse(localStorage.getItem('pwa-install-state') || 'null');
      return d?.permanent === true;
    } catch { return false; }
  }

  function esIOS(): boolean {
    return /iPhone|iPad|iPod/i.test(navigator.userAgent)
        && !(window as Window & { MSStream?: unknown }).MSStream;
  }

  function mostrarBoton() {
    if (!foot || !btn) return;
    if (yaInstalada()) return;
    if (estadoPermanente()) return;
    foot.hidden = false;
  }

  // Mostrar botón si corresponde
  mostrarBoton();

  btn?.addEventListener('click', () => {
    const prompt = (window as Window & { __pwaPrompt?: BeforeInstallPromptEvent }).__pwaPrompt;

    if (prompt) {
      prompt.prompt().then(({ outcome }) => {
        if (outcome === 'accepted') {
          foot!.hidden = true;
          localStorage.setItem('pwa-install-state', JSON.stringify({ permanent: true }));
        }
        (window as Window & { __pwaPrompt?: BeforeInstallPromptEvent }).__pwaPrompt = undefined;
      });
    } else if (esIOS()) {
      // Activar el banner iOS
      const iosBanner = document.getElementById('pwa-ios');
      if (iosBanner) {
        iosBanner.hidden = false;
        requestAnimationFrame(() => iosBanner.classList.add('visible'));
      }
    }
  });

  // Esconder el botón si el usuario instala desde el banner
  window.addEventListener('appinstalled', () => {
    if (foot) foot.hidden = true;
  });
</script>
