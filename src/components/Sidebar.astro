---
import { groups } from '../data/sections';

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // e.g. '/git-guia-equipo-astro'
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<div class="sidebar-inner">
  <div class="sidebar-head">
    <a href={import.meta.env.BASE_URL} class="sidebar-home-link">
      <span class="sidebar-badge">v3.0</span>
      <p class="sidebar-title">Git Guía <span>del Equipo</span></p>
    </a>
    <div class="offline-pill offline-pill--sidebar" id="offlineBadgeSidebar" aria-live="polite" aria-atomic="true" hidden>
      <span class="offline-dot" aria-hidden="true"></span>Sin conexión
    </div>
  </div>

  <nav class="sidebar-nav" aria-label="Secciones de la guía">
    {groups.map(group => (
      <div class="nav-group">
        <span class="nav-group-label">{group.label}</span>
        <ul class="nav-list">
          {group.items.map(item => (
            <li>
              <a
                href={base + item.href}
                class:list={["nav-link", { "is-active": pathname === base + item.href }]}
                aria-current={pathname === base + item.href ? "page" : undefined}
              >
                <span class="nav-text">{item.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>

  <div class="sidebar-foot">
    <span class="sidebar-foot-text">git-guia-equipo · actualizar cuando el equipo lo decida</span>
  </div>
</div>

<style>
  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .sidebar-head {
    padding: 22px 20px 18px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .sidebar-home-link {
    text-decoration: none;
    display: block;
  }

  .sidebar-badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--accent);
    background: rgba(124, 106, 247, 0.1);
    border: 1px solid rgba(124, 106, 247, 0.22);
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 10px;
  }

  .sidebar-title {
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin: 0;
  }

  .sidebar-title span {
    display: block;
    color: var(--muted);
    font-weight: 400;
    font-size: 12px;
    margin-top: 2px;
  }

  .sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 16px 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .nav-group { margin-bottom: 22px; }

  .nav-group-label {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 8px;
    margin-bottom: 5px;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 7px;
    text-decoration: none;
    color: #9090aa;
    font-size: 13px;
    line-height: 1.35;
    transition: background 0.14s ease, color 0.14s ease;
    width: 100%;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
    outline: none;
  }

  .nav-link.is-active {
    background: rgba(124, 106, 247, 0.12);
    color: var(--accent);
  }

  .nav-text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-foot {
    padding: 14px 20px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  .sidebar-foot-text {
    font-size: 10px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    line-height: 1.6;
    opacity: 0.7;
  }
</style>
