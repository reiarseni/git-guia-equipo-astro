---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Banner Chromium (Desktop / Android) -->
<div id="pwa-chromium" class="pwa-banner" hidden role="dialog" aria-label="Instalar aplicación">
  <img src={`${base}/icons/icon-192.svg`} alt="" class="pwa-banner-icon" width="36" height="36" aria-hidden="true" />
  <div class="pwa-banner-body">
    <span class="pwa-banner-title">Instala la app</span>
    <span class="pwa-banner-sub" id="chromium-sub"></span>
  </div>
  <button id="btn-install" class="pwa-btn-install">Instalar</button>
  <button id="btn-chromium-close" class="pwa-btn-close" aria-label="Cerrar">✕</button>
</div>

<!-- Banner iOS -->
<div id="pwa-ios" class="pwa-banner" hidden role="dialog" aria-label="Añadir a pantalla de inicio">
  <img src={`${base}/icons/icon-192.svg`} alt="" class="pwa-banner-icon" width="36" height="36" aria-hidden="true" />
  <div class="pwa-banner-body">
    <span class="pwa-banner-title">Añade esta app a tu inicio</span>
    <span class="pwa-banner-sub">Toca <strong>Compartir</strong> ⬆ → <strong>Añadir a inicio</strong></span>
  </div>
  <button id="btn-ios-ok" class="pwa-btn-install">Entendido</button>
  <button id="btn-ios-close" class="pwa-btn-close" aria-label="Cerrar">✕</button>
</div>

<style>
  .pwa-banner {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 24px));
    z-index: 9999;
    width: calc(100% - 32px);
    max-width: 480px;
    background: #1e1e2e;
    border: 1px solid rgba(124, 106, 247, 0.3);
    border-radius: 14px;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
    transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1), opacity 300ms ease;
    opacity: 0;
  }

  .pwa-banner.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .pwa-banner-icon {
    border-radius: 8px;
    flex-shrink: 0;
  }

  .pwa-banner-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pwa-banner-title {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pwa-banner-sub {
    font-size: 12px;
    color: #a0a0b8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pwa-banner-sub strong { color: #d0d0e8; font-weight: 500; }

  .pwa-btn-install {
    background: var(--accent, #7c6af7);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 7px 14px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    flex-shrink: 0;
    white-space: nowrap;
    min-height: 34px;
    transition: filter 200ms;
  }

  .pwa-btn-install:hover        { filter: brightness(1.12); }
  .pwa-btn-install:focus-visible {
    outline: 2px solid var(--accent, #7c6af7);
    outline-offset: 2px;
  }

  .pwa-btn-close {
    background: transparent;
    border: none;
    color: #666680;
    font-size: 14px;
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    flex-shrink: 0;
    min-width: 28px;
    min-height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 150ms, background 150ms;
  }

  .pwa-btn-close:hover,
  .pwa-btn-close:focus-visible {
    color: #e0e0f0;
    background: rgba(255, 255, 255, 0.08);
    outline: none;
  }

  @media (max-width: 400px) {
    .pwa-banner { bottom: 12px; padding: 10px 12px; gap: 10px; }
    .pwa-banner-sub { display: none; }
  }
</style>

<script>
  interface BeforeInstallPromptEvent extends Event {
    prompt(): Promise<{ outcome: 'accepted' | 'dismissed' }>;
  }

  // ── Captura inmediata ─────────────────────────────────
  let deferredPrompt: BeforeInstallPromptEvent | null = null;
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e as BeforeInstallPromptEvent;
    // Compartir el prompt con otros componentes (ej: botón del sidebar)
    (window as Window & { __pwaPrompt?: BeforeInstallPromptEvent }).__pwaPrompt = deferredPrompt;
  });

  // ── Anti-spam ─────────────────────────────────────────
  const KEY = 'pwa-install-state';

  function debeMostrar(): boolean {
    const raw = localStorage.getItem(KEY);
    if (!raw) return true;
    const d = JSON.parse(raw);
    if (d.permanent) return false;
    if (d.lastShown && (Date.now() - d.lastShown) / 86_400_000 < 7) return false;
    return true;
  }

  function cerrar(): void {
    localStorage.setItem(KEY, JSON.stringify({ permanent: true }));
  }

  function instalada(): void {
    localStorage.setItem(KEY, JSON.stringify({ permanent: true }));
  }

  // ── Detección ─────────────────────────────────────────
  function yaInstalada(): boolean {
    return window.matchMedia('(display-mode: standalone)').matches
        || (navigator as Navigator & { standalone?: boolean }).standalone === true;
  }

  function esIOS(): boolean {
    return /iPhone|iPad|iPod/i.test(navigator.userAgent)
        && !(window as Window & { MSStream?: unknown }).MSStream;
  }

  function esDesktop(): boolean {
    return !/Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
  }

  // ── Mostrar / ocultar banner ──────────────────────────
  function mostrar(id: string): void {
    const el = document.getElementById(id)!;
    el.hidden = false;
    requestAnimationFrame(() => el.classList.add('visible'));
  }

  function ocultar(id: string): void {
    const el = document.getElementById(id)!;
    el.classList.remove('visible');
    setTimeout(() => { el.hidden = true; }, 300);
  }

  // ── ESC cierra cualquier banner visible ───────────────
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    ['pwa-chromium', 'pwa-ios'].forEach(id => {
      const el = document.getElementById(id);
      if (el && !el.hidden) { ocultar(id); cerrar(); }
    });
  });

  // ── Flujo principal ───────────────────────────────────
  setTimeout(() => {
    if (yaInstalada()) return;
    if (!debeMostrar()) return;

    if (deferredPrompt) {
      document.getElementById('chromium-sub')!.textContent = esDesktop()
        ? 'Disponible como app nativa en tu escritorio.'
        : 'Acceso rápido desde tu pantalla de inicio.';

      mostrar('pwa-chromium');

      document.getElementById('btn-install')!.addEventListener('click', async () => {
        ocultar('pwa-chromium');
        const { outcome } = await deferredPrompt!.prompt();
        deferredPrompt = null;
        (window as Window & { __pwaPrompt?: BeforeInstallPromptEvent }).__pwaPrompt = undefined;
        outcome === 'accepted' ? instalada() : cerrar();
      });

      document.getElementById('btn-chromium-close')!.addEventListener('click', () => {
        ocultar('pwa-chromium');
        cerrar();
      });

    } else if (esIOS()) {
      mostrar('pwa-ios');

      document.getElementById('btn-ios-ok')!.addEventListener('click', () => {
        ocultar('pwa-ios');
        cerrar();
      });

      document.getElementById('btn-ios-close')!.addEventListener('click', () => {
        ocultar('pwa-ios');
        cerrar();
      });
    }
  }, 2000);

  window.addEventListener('appinstalled', () => {
    ocultar('pwa-chromium');
    instalada();
  });
</script>
