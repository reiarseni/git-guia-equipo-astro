---
import '../styles/global.css';
import PwaInstallPrompt from '../components/PwaInstallPrompt.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Guía oficial del flujo de trabajo con Git y GitLab para el equipo de desarrollo.">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <!-- PWA -->
  <link rel="manifest" href={`${base}/manifest.json`}>
  <meta name="theme-color" content="#7c6af7">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Git Guía">
  <link rel="apple-touch-icon" href={`${base}/icons/icon-192.svg`}>
</head>
<body>

  <!-- Topbar móvil -->
  <div class="mobile-topbar" id="mobileTopbar">
    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="sidebar">
      <svg class="icon-hamburger" viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg class="icon-close" viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Overlay oscuro (móvil) -->
  <div class="overlay" id="overlay" aria-hidden="true"></div>

  <!-- Sidebar de navegación -->
  <aside class="sidebar" id="sidebar" aria-label="Navegación principal">
    <slot name="sidebar" />
  </aside>

  <!-- Contenido principal -->
  <div class="page-wrapper">
    <slot />
  </div>

  <script>
    const menuToggle = document.getElementById('menuToggle');
    const sidebar    = document.getElementById('sidebar');
    const overlay    = document.getElementById('overlay');
    let isOpen = false;

    function openMenu() {
      isOpen = true;
      sidebar?.classList.add('is-open');
      overlay?.classList.add('is-visible');
      menuToggle?.classList.add('is-open');
      menuToggle?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      sidebar?.classList.remove('is-open');
      overlay?.classList.remove('is-visible');
      menuToggle?.classList.remove('is-open');
      menuToggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    menuToggle?.addEventListener('click', () => { isOpen ? closeMenu() : openMenu(); });
    overlay?.addEventListener('click', closeMenu);

    // Cerrar al hacer click en un enlace del menú (en móvil)
    document.getElementById('sidebar')?.addEventListener('click', (e) => {
      if ((e.target as Element).closest('.nav-link')) closeMenu();
    });

    // Tecla Escape cierra el menú
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });

  </script>

  <!-- Service Worker -->
  <script>
    if ('serviceWorker' in navigator) {
      /* @vite-ignore */
      navigator.serviceWorker.register(
        '/git-guia-equipo-astro/sw.js',
        { scope: '/git-guia-equipo-astro/' }
      ).catch(() => { /* SW opcional, no bloquear si falla */ });
    }
  </script>

  <PwaInstallPrompt />
</body>
</html>
