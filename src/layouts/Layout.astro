---
import '../styles/global.css';
import PwaInstallPrompt from '../components/PwaInstallPrompt.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Guía oficial del flujo de trabajo con Git y GitLab para el equipo de desarrollo.">
  <meta name="theme-color" content="#7c6af7">
  <title>{title}</title>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={base + '/icons/icon-192.svg'}>
  <link rel="icon" type="image/png" href={base + '/icons/icon-192.png'}>

  <!-- PWA -->
  <link rel="manifest" href={base + '/manifest.json'}>
  <link rel="apple-touch-icon" href={base + '/icons/icon-192.png'}>

  <!-- Fuentes -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Banner de actualización disponible -->
  <div id="update-banner" class="update-banner" hidden role="alert" aria-live="assertive">
    <span class="update-banner-text">Nueva versión disponible</span>
    <button id="btn-update" class="update-btn-update">Actualizar</button>
    <button id="btn-update-close" class="update-btn-close" aria-label="Cerrar">✕</button>
  </div>

  <!-- Topbar móvil -->
  <div class="mobile-topbar" id="mobileTopbar">
    <div class="offline-pill" id="offlinePill" aria-live="polite" aria-atomic="true" hidden>
      <span class="offline-dot" aria-hidden="true"></span>Sin conexión
    </div>
    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="sidebar">
      <svg class="icon-hamburger" viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg class="icon-close" viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Overlay oscuro (móvil) -->
  <div class="overlay" id="overlay" aria-hidden="true"></div>

  <!-- Sidebar de navegación -->
  <aside class="sidebar" id="sidebar" aria-label="Navegación principal">
    <slot name="sidebar" />
  </aside>

  <!-- Contenido principal -->
  <div class="page-wrapper">
    <slot />
  </div>

  <!-- Prompt de instalación PWA -->
  <PwaInstallPrompt />

  <style>
    /* ── Banner de actualización ──────────────────────────── */
    .update-banner {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%) translateY(calc(100% + 24px));
      z-index: 9998;
      width: calc(100% - 32px);
      max-width: 440px;
      background: #1e1e2e;
      border: 1px solid rgba(124, 106, 247, 0.45);
      border-radius: 14px;
      padding: 12px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
      opacity: 0;
      transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1), opacity 300ms ease;
    }
    .update-banner.visible {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    .update-banner-text {
      flex: 1;
      font-size: 13px;
      font-weight: 600;
      color: #e8e8f0;
    }
    .update-btn-update {
      background: var(--accent, #7c6af7);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 7px 14px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: filter 200ms;
    }
    .update-btn-update:hover { filter: brightness(1.12); }
    .update-btn-close {
      background: transparent;
      border: none;
      color: #666680;
      font-size: 14px;
      cursor: pointer;
      padding: 4px;
      border-radius: 6px;
      min-width: 28px;
      min-height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 150ms, background 150ms;
    }
    .update-btn-close:hover { color: #e0e0f0; background: rgba(255,255,255,0.08); }
  </style>

  <!-- Menú móvil -->
  <script>
    const menuToggle = document.getElementById('menuToggle');
    const sidebar    = document.getElementById('sidebar');
    const overlay    = document.getElementById('overlay');
    let isOpen = false;

    function openMenu() {
      isOpen = true;
      sidebar?.classList.add('is-open');
      overlay?.classList.add('is-visible');
      menuToggle?.classList.add('is-open');
      menuToggle?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      sidebar?.classList.remove('is-open');
      overlay?.classList.remove('is-visible');
      menuToggle?.classList.remove('is-open');
      menuToggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    menuToggle?.addEventListener('click', () => { isOpen ? closeMenu() : openMenu(); });
    overlay?.addEventListener('click', closeMenu);

    document.getElementById('sidebar')?.addEventListener('click', (e) => {
      if ((e.target as Element).closest('.nav-link')) closeMenu();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });
  </script>

  <!-- Indicador offline -->
  <script>
    const pill = document.getElementById('offlinePill');
    const offlineBadge = document.getElementById('offlineBadgeSidebar');

    function setOffline(offline: boolean) {
      if (pill) pill.hidden = !offline;
      if (offlineBadge) offlineBadge.hidden = !offline;
    }

    setOffline(!navigator.onLine);
    window.addEventListener('offline', () => setOffline(true));
    window.addEventListener('online',  () => setOffline(false));
  </script>

  <!-- Service Worker + banner de actualización -->
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/git-guia-equipo-astro/sw.js', {
        scope: '/git-guia-equipo-astro/'
      }).then(reg => {

        // Detectar SW esperando en el momento del registro
        if (reg.waiting) {
          showUpdateBanner(reg.waiting);
        }

        // Detectar cuando llega un nuevo SW
        reg.addEventListener('updatefound', () => {
          const newWorker = reg.installing;
          if (!newWorker) return;
          newWorker.addEventListener('statechange', () => {
            if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
              showUpdateBanner(newWorker);
            }
          });
        });

      }).catch(err => console.warn('[SW] registro fallido:', err));

      // Cuando el SW toma control, recargar la página
      let refreshing = false;
      navigator.serviceWorker.addEventListener('controllerchange', () => {
        if (!refreshing) {
          refreshing = true;
          window.location.reload();
        }
      });
    }

    function showUpdateBanner(worker: ServiceWorker) {
      const banner = document.getElementById('update-banner') as HTMLElement;
      if (!banner) return;

      banner.hidden = false;
      requestAnimationFrame(() => banner.classList.add('visible'));

      document.getElementById('btn-update')?.addEventListener('click', () => {
        banner.classList.remove('visible');
        worker.postMessage('SKIP_WAITING');
      });

      document.getElementById('btn-update-close')?.addEventListener('click', () => {
        banner.classList.remove('visible');
        setTimeout(() => { banner.hidden = true; }, 300);
      });
    }
  </script>
</body>
</html>
